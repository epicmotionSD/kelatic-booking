# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=YOUR_STRIPE_TEST_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_TEST_PUBLISHABLE_KEY

# Stripe Terminal (POS) - Get from Stripe Dashboard > Terminal > Locations
STRIPE_TERMINAL_LOCATION_ID=tml_xxx

# Stripe Subscription Products (x3o.ai Revenue Model)
# Create these in Stripe Dashboard > Products, then add Price IDs here
# Trinity AI Monthly: $297/mo
STRIPE_PRICE_TRINITY_MONTHLY=price_xxx
# Trinity AI Annual: $2,970/year (save $594)
STRIPE_PRICE_TRINITY_ANNUAL=price_xxx
# Revenue Sprint: $1,500 one-time
STRIPE_PRICE_REVENUE_SPRINT=price_xxx

# Anthropic (AI Chatbot)
ANTHROPIC_API_KEY=sk-ant-xxx

# SendGrid (Email Notifications)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=bookings@kelatic.com
EMAIL_PROVIDER=sendgrid

# Mailchimp Transactional (optional, set EMAIL_PROVIDER=mailchimp)
MAILCHIMP_TRANSACTIONAL_API_KEY=your_mailchimp_transactional_key
MAILCHIMP_TRANSACTIONAL_API_BASE=https://mandrillapp.com/api/1.0
MAILCHIMP_WEBHOOK_SECRET=your_mailchimp_webhook_secret
MAILCHIMP_WEBHOOK_ALLOW_UNSIGNED=false

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1234567890
SMS_PROVIDER=twilio

# Push Notifications (VAPID Keys)
# Generate with: npm run generate:vapid
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@yourdomain.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Cron Job Security (generate a random string)
CRON_SECRET=your-random-secret-string

# Google Ads (Conversion Tracking)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-937265883
NEXT_PUBLIC_GOOGLE_ADS_BOOKING_CONVERSION=XXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION=XXXXXXXXXXX

# Instagram Integration (for portfolio images)
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=x3o.ai

# Phase 1: Feature Flags (Email-only by default)
NEXT_PUBLIC_SMS_ENABLED=false
SMS_ENABLED=false
SMS_SEND_DISABLED=true
TWILIO_A2P_APPROVED=false
